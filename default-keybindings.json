  {
    "keyCombo": "Shift+$mod+s",
    "type": "app",
    "command": "~/.config/MyI3Config/scripts/screenshot.sh"
  },
  {
    "keyCombo": "$mod+p",
    "type": "app",
    "command": "~/.config/MyI3Config/scripts/display-tool.sh"
  },
  {
    "keyCombo": "$mod+l",
    "type": "app",
    "command": "~/.config/MyI3Config/scripts/lock.sh"
  }
